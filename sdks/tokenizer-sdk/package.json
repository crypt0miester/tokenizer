{
  "name": "@tokenizer/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Tokenizer on-chain program",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "check": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solana/kit": "^5.0.0",
    "gill": "^0.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "litesvm": "^0.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
